# ─── Orchestrateur Organigrad — template variables d'environnement ───────────
# Copier en .env (ou .env.production / .env.vps selon la cible) puis remplir.
# ⚠️  Ne JAMAIS committer un fichier rempli : tout fichier .env* (sauf .example
#     et .test) est ignoré par .gitignore.

# ── Mode de fonctionnement ───────────────────────────────────────────────────
# Si SUPABASE_DB_URL est défini → mode Postgres + auth par clé API (production).
# Sinon → mode in-memory (dev local / tests), sans authentification.

# Port d'écoute HTTP (défaut : 3001)
PORT=3001

# ── Base de données Postgres (Supabase) ──────────────────────────────────────
# Connection string Postgres avec le rôle service_role.
# Format : postgresql://<user>:<password>@<host>:<port>/<db>?sslmode=require
# ⚠️  SECRET — donne un accès total à la base. À stocker hors dépôt et à
#     renouveler si jamais exposé.
SUPABASE_DB_URL=postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require

# ── Edge Function e-mail (Supabase) ──────────────────────────────────────────
# URL de la fonction notify-email déployée.
EMAIL_EDGE_FUNCTION_URL=https://<project-ref>.functions.supabase.co/notify-email

# Clé service_role utilisée pour appeler l'Edge Function.
# ⚠️  SECRET — à ne jamais exposer côté client ni journaliser.
SUPABASE_SERVICE_ROLE_KEY=REPLACE_WITH_SERVICE_ROLE_KEY

# ── Notifications Slack (webhooks entrants) ──────────────────────────────────
# ⚠️  SECRETS — toute personne possédant l'URL peut poster dans le canal.
# Canal #validations (ping HITL quand un nœud attend une validation humaine).
SLACK_VALIDATIONS=https://hooks.slack.com/services/REPLACE/WITH/WEBHOOK
# Canal #flux-agents (journal des transitions).
SLACK_FLUX=https://hooks.slack.com/services/REPLACE/WITH/WEBHOOK

# ── Divers ───────────────────────────────────────────────────────────────────
# URL publique de la SPA (pour construire les liens dans les notifications).
APP_URL=https://app.example.com
